{
  "name": "wraps-monorepo",
  "private": true,
  "description": "Wraps - wrap your AWS account's SES, SNS, SQS, IoT, and more",
  "repository": {
    "type": "git",
    "url": "https://github.com/wraps-team/wraps.git"
  },
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:ee": "turbo run test:ee",
    "test:coverage": "turbo run test:coverage --filter=@wraps.dev/cli",
    "typecheck": "turbo run typecheck",
    "check": "npx ultracite@latest check",
    "check:errors": "npx ultracite@7.0.12 check --diagnostic-level=error",
    "check:all": "pnpm check:errors && pnpm typecheck && pnpm build && pnpm test",
    "fix": "npx ultracite@latest fix",
    "clean": "turbo run clean && rm -rf node_modules",
    "cli": "node packages/cli/dist/cli.js",
    "tui": "pnpm -F=tui tui",
    "sst:dev": "dotenv -e apps/web/.env.local -- sst dev",
    "sst:deploy": "sst deploy",
    "sst:remove": "sst remove"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@types/aws-lambda": "8.10.157",
    "@types/node": "24.10.0",
    "dotenv": "catalog:",
    "dotenv-cli": "11.0.0",
    "pnpm": "10.28.2",
    "sst": "3.17.25",
    "turbo": "^2.2.3",
    "ultracite": "6.3.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.4",
      "@types/react-dom": "19.2.3",
      "hono": "^4.11.3",
      "@modelcontextprotocol/sdk": "^1.25.1",
      "nodemailer": "^7.0.12",
      "path-to-regexp@6": "^6.3.0",
      "tar": "^7.5.0",
      "@smithy/types": "^4.12.0"
    }
  },
  "dependencies": {
    "@react-email/components": "1.0.1"
  }
}
