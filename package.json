{
  "name": "wraps-monorepo",
  "private": true,
  "description": "Wraps - wrap your AWS account's SES, SNS, SQS, IoT, and more",
  "repository": {
    "type": "git",
    "url": "https://github.com/wraps-team/wraps.git"
  },
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:ee": "turbo run test:ee",
    "test:coverage": "turbo run test:coverage --filter=@wraps.dev/cli",
    "typecheck": "turbo run typecheck",
    "check": "npx ultracite@latest check",
    "check:errors": "npx ultracite@7.0.12 check --diagnostic-level=error",
    "test:guardrails": "vitest run --config vitest.config.ts && npx code-guardrails scan .",
    "check:all": "pnpm check:errors && pnpm typecheck && pnpm test:guardrails && pnpm build && pnpm test",
    "fix": "npx ultracite@latest fix",
    "clean": "turbo run clean && rm -rf node_modules",
    "cli": "WRAPS_API_URL=http://localhost:3001 WRAPS_APP_URL=http://localhost:3000 node packages/cli/dist/cli.js",
    "tui": "pnpm -F=tui tui",
    "sst:dev": "dotenv -e apps/web/.env.local -- sst dev",
    "sst:deploy": "sst deploy",
    "sst:remove": "sst remove"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@react-email/preview-server": "4.3.2",
    "@types/aws-lambda": "8.10.157",
    "@types/node": "24.10.0",
    "dotenv": "catalog:",
    "dotenv-cli": "11.0.0",
    "pnpm": "10.28.2",
    "react-email": "4.3.2",
    "sst": "3.17.25",
    "turbo": "^2.2.3",
    "ultracite": "6.3.2",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.4",
      "@types/react-dom": "19.2.3",
      "hono": "^4.11.7",
      "@modelcontextprotocol/sdk": "^1.26.0",
      "nodemailer": "^7.0.12",
      "path-to-regexp@6": "^6.3.0",
      "tar": "^7.5.7",
      "@smithy/types": "^4.12.0",
      "fast-xml-parser": "^5.3.4",
      "@isaacs/brace-expansion": "^5.0.1",
      "lodash": "^4.17.23",
      "qs": "^6.14.2",
      "markdown-it": "^14.1.1",
      "seroval": "^1.4.1"
    },
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": ">=4.0.0"
        }
      }
    }
  },
  "dependencies": {
    "@react-email/components": "1.0.1"
  }
}
