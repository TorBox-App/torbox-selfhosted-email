# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
CORS_ORIGIN=http://localhost:3000

# Better Auth (generate a random secret key)
BETTER_AUTH_SECRET=your-secret-key-here

# Passkey Configuration (optional)
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Wraps

# OAuth (optional - for social login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS Backend Credentials (for IAM role assumption)
# IMPORTANT: This should be a DIFFERENT AWS account from where you deploy CloudFormation stacks
# - AWS_BACKEND_ACCOUNT_ID: The Wraps backend AWS account (will assume roles in customer accounts)
# - Customer accounts: Deploy CloudFormation stack to create IAM roles that trust this account
#
# Option 1: Use AWS Profile (recommended for local development)
# Set AWS_PROFILE to use credentials from ~/.aws/credentials
# AWS_PROFILE=wraps-backend
#
# Option 2: Use explicit credentials (recommended for production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
#
AWS_BACKEND_ACCOUNT_ID=123456789012

# Development Mode (optional - for local testing)
# When enabled, skips IAM role assumption and uses ambient AWS credentials
# This allows you to test with your own AWS account without setting up trust relationships
#
# To enable dev mode:
# 1. Set DEV_MODE_SKIP_ROLE_ASSUMPTION=true
# 2. Set AWS_PROFILE to your test AWS account profile (from ~/.aws/credentials)
# 3. In your database, create an AWS account with the correct accountId and region
#    (roleArn and externalId can be any dummy values - they'll be ignored in dev mode)
#
# Example:
# DEV_MODE_SKIP_ROLE_ASSUMPTION=true
# AWS_PROFILE=my-test-account
#
# Note: Dev mode is ONLY for local development. Never use in production!

# Email (using @wraps.dev/email)
# The "from" address for system emails (invitations, notifications, etc.)
EMAIL_FROM=noreply@yourdomain.com

# Wraps Email Role ARN (for dogfooding)
# This is the IAM role created by `wraps init` in your DOGFOOD AWS account
# The role must trust your backend AWS account (AWS_ROLE_ARN) to assume it
#
# Trust policy example:
# {
#   "Version": "2012-10-17",
#   "Statement": [{
#     "Effect": "Allow",
#     "Principal": { "AWS": "arn:aws:iam::BACKEND_ACCOUNT_ID:root" },
#     "Action": "sts:AssumeRole"
#   }]
# }
WRAPS_EMAIL_ROLE_ARN=arn:aws:iam::DOGFOOD_ACCOUNT_ID:role/wraps-email-role

# Stripe (optional - for billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (for subscription plans)
STRIPE_STARTER_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_GROWTH_ANNUAL_PRICE_ID=

# AI (Anthropic via Vercel AI Gateway)
# Get your key from: https://vercel.com/dashboard/ai-gateway
ANTHROPIC_API_KEY=

# Wraps Platform API Key (for signup tracking & product updates subscription)
# This is our own API key for dogfooding - creates contacts when users sign up
WRAPS_API_KEY=

# PostHog Analytics
# Get your project API key from: https://us.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog Source Maps (for error tracking stack traces)
# Get your personal API key from: https://us.posthog.com/settings/user-api-keys
# Get your environment ID from: https://us.posthog.com/settings/project-error-tracking#source-maps
POSTHOG_PERSONAL_API_KEY=
POSTHOG_ENV_ID=

# Axiom Observability
# Lambda functions: managed via `sst secret set AxiomToken <value>`
# Vercel: set AXIOM_TOKEN in Vercel env vars dashboard
AXIOM_TOKEN=
AXIOM_DATASET=wraps
