{
  "name": "@wraps/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "portless api.wraps bun run --env-file=../web/.env.local --watch src/index.ts",
    "build": "bun build src/lambda.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude='**/*.integration.test.ts'",
    "test:ee": "vitest run --testNamePattern='.*' src/\\(ee\\) --exclude='**/*.integration.test.ts'",
    "test:watch": "vitest --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "catalog:",
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/client-pinpoint-sms-voice-v2": "catalog:",
    "@aws-sdk/client-scheduler": "catalog:",
    "@aws-sdk/client-ses": "catalog:",
    "@aws-sdk/client-sesv2": "catalog:",
    "@aws-sdk/client-sqs": "catalog:",
    "@aws-sdk/client-sts": "catalog:",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/swagger": "^1.3.1",
    "@react-email/render": "catalog:",
    "@sentry/aws-serverless": "10.46.0",
    "@sentry/profiling-node": "10.46.0",
    "@smithy/node-http-handler": "^4.8.2",
    "@wraps.dev/client": "0.6.1",
    "@wraps.dev/email-check": "workspace:*",
    "@wraps/auth": "workspace:*",
    "@wraps/db": "workspace:*",
    "@wraps/email": "workspace:*",
    "@wraps/email-send": "workspace:*",
    "@wraps/template-render": "workspace:*",
    "@wraps/unsubscribe-token": "workspace:*",
    "croner": "9.1.0",
    "drizzle-orm": "catalog:",
    "elysia": "^1.4.29",
    "handlebars": "catalog:",
    "jose": "6.1.3",
    "pg": "^8.22.0",
    "pino": "10.1.0",
    "posthog-node": "catalog:",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@aws-sdk/credential-providers": "catalog:",
    "@types/aws-lambda": "^8.10.162",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "catalog:",
    "dotenv": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
