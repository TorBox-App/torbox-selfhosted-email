{
  "name": "@wraps/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --env-file=../web/.env.local --watch src/index.ts",
    "build": "bun build src/lambda.ts --outdir dist --target node",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude='**/*.integration.test.ts'",
    "test:ee": "vitest run --testNamePattern='.*' src/\\(ee\\) --exclude='**/*.integration.test.ts'",
    "test:watch": "vitest --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.927.0",
    "@aws-sdk/client-pinpoint-sms-voice-v2": "3.955.0",
    "@aws-sdk/client-scheduler": "3.958.0",
    "@aws-sdk/client-ses": "^3.927.0",
    "@aws-sdk/client-sesv2": "3.962.0",
    "@aws-sdk/client-sqs": "^3.927.0",
    "@aws-sdk/client-sts": "^3.927.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@react-email/render": "2.0.4",
    "@sentry/aws-serverless": "10.46.0",
    "@sentry/profiling-node": "10.46.0",
    "@smithy/node-http-handler": "^4.4.14",
    "@wraps.dev/client": "0.6.1",
    "@wraps/auth": "workspace:*",
    "@wraps/db": "workspace:*",
    "@wraps/email": "workspace:*",
    "@wraps/email-check": "workspace:*",
    "@wraps/template-render": "workspace:*",
    "croner": "9.1.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.27",
    "handlebars": "4.7.9",
    "jose": "6.1.3",
    "pg": "^8.16.2",
    "pino": "10.1.0",
    "posthog-node": "^5.29.2"
  },
  "devDependencies": {
    "@aws-sdk/credential-providers": "3.962.0",
    "@types/aws-lambda": "^8.10.157",
    "@types/pg": "^8.15.4",
    "@vitest/coverage-v8": "4.0.7",
    "dotenv": "17.2.3",
    "typescript": "5.8.3",
    "vitest": "4.0.8"
  }
}
