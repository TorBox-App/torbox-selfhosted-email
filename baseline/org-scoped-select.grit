language js

// Require db.select().from(<orgScopedTable>).where(...) chains to include a
// syntactic organizationId reference inside the WHERE predicate.
//
// Cross-org IDOR defense on reads — prevents returning another org's rows
// even when a caller passes a valid-looking id.
//
// Escape hatch: use `// biome-ignore lint/plugin: <reason>` on the .where(
// line when scope is guaranteed by context.
`$prefix.from($table).where($where)` as $source where {
  $table <: or {
    `contact`,
    `topic`,
    `topicSettings`,
    `template`,
    `reusableBlock`,
    `templateVariable`,
    `brandKit`,
    `aiConversation`,
    `workflow`,
    `workflowExecution`,
    `awsAccount`,
    `apiKey`,
    `auditLog`,
    `batchSend`,
    `messageSend`,
    `segment`,
    `contactEvent`,
    `emailTemplate`,
    `organizationExtension`,
    `member`,
    `invitation`,
    `statement`,
    `aiUsageMonthly`,
    `aiUsageLog`,
    `apiUsageDaily`,
    `apiRateLimitWindow`,
    `messageUsageMonthly`,
    `eventUsageMonthly`
  },
  ! $where <: contains `organizationId`,
  register_diagnostic(span=$source, severity="warn", message="db.select().from(<orgScopedTable>) WHERE clause missing organizationId scope. Add eq(<table>.organizationId, ...) to the predicate, or add `// biome-ignore lint/plugin: <reason>` on the .where( line if the scope is guaranteed via a JOINed org-scoped table.")
}
