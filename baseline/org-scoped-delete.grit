language js

// Require db.delete(<orgScopedTable>).where(...) chains to include a syntactic
// `<table>.organizationId` reference inside the WHERE predicate.
//
// Cross-org IDOR defense on mass-delete operations — arguably the most
// important scope check since an unbounded DELETE can wipe other orgs' data.
//
// Escape hatch: use `// biome-ignore lint/plugin: <reason>` on the .where(
// line when scope is guaranteed by context.
`db.delete($table).where($where)` as $source where {
  $table <: or {
    `contact`,
    `topic`,
    `topicSettings`,
    `template`,
    `reusableBlock`,
    `templateVariable`,
    `brandKit`,
    `aiConversation`,
    `workflow`,
    `workflowExecution`,
    `awsAccount`,
    `apiKey`,
    `auditLog`,
    `batchSend`,
    `messageSend`,
    `segment`,
    `contactEvent`,
    `emailTemplate`,
    `organizationExtension`,
    `member`,
    `invitation`,
    `statement`,
    `aiUsageMonthly`,
    `aiUsageLog`,
    `apiUsageDaily`,
    `apiRateLimitWindow`,
    `messageUsageMonthly`,
    `eventUsageMonthly`
  },
  ! $where <: contains `$table.organizationId`,
  register_diagnostic(span=$source, severity="warn", message="db.delete(<orgScopedTable>) WHERE clause missing <table>.organizationId scope. Add eq(<table>.organizationId, ...) to the predicate, or add `// biome-ignore lint/plugin: <reason>` on the .where( line.")
}
