{
  "name": "@wraps/email",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.490.0",
    "@aws-sdk/client-sesv2": "^3.490.0",
    "@aws-sdk/client-sts": "^3.927.0",
    "@react-email/render": "2.0.4",
    "@vercel/oidc-aws-credentials-provider": "3.0.4",
    "@wraps.dev/email": "^0.5.1",
    "@wraps/db": "workspace:*",
    "@wraps/template-render": "workspace:*",
    "jose": "6.1.3"
  }
}
