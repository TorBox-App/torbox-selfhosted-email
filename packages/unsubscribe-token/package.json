{
  "name": "@wraps/unsubscribe-token",
  "version": "0.1.0",
  "private": true,
  "description": "Shared unsubscribe token implementation for Wraps API and web. RFC 8058 one-click-unsubscribe JWT (HS256, 90-day expiry).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jose": "6.1.3"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
