{
  "name": "@wraps/auth",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "stripe listen --forward-to https://web.wraps.localhost/api/auth/stripe/webhook",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vite": "^7.3.5",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "@better-auth/core": "1.6.23",
    "@better-auth/passkey": "1.6.23",
    "@better-auth/scim": "1.6.23",
    "@better-auth/sso": "1.6.23",
    "@better-auth/stripe": "1.6.23",
    "@wraps.dev/client": "0.4.0",
    "@wraps.dev/email": "^0.5.1",
    "@wraps.dev/sms": "^0.1.6",
    "@wraps/db": "workspace:*",
    "@wraps/email": "workspace:*",
    "better-auth": "catalog:",
    "better-inbox": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "posthog-node": "catalog:",
    "stripe": "catalog:",
    "zod": "catalog:"
  }
}
