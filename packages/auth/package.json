{
  "name": "@wraps/auth",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "@better-auth/passkey": "1.4.10",
    "@better-auth/stripe": "1.4.10",
    "@wraps.dev/client": "0.4.0",
    "@wraps.dev/email": "^0.4.0",
    "@wraps.dev/sms": "^0.1.1",
    "@wraps/db": "workspace:*",
    "@wraps/email": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.44.2",
    "stripe": "catalog:",
    "zod": "catalog:"
  }
}
