{
  "name": "@wraps.dev/cli",
  "version": "2.18.12",
  "description": "Deploy email, SMS, and CDN infrastructure to your AWS account with one command. Sets up SES with DKIM/SPF/DMARC, event processing, and history automatically.",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "wraps": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wraps-team/wraps.git",
    "directory": "packages/cli"
  },
  "homepage": "https://wraps.dev",
  "bugs": {
    "url": "https://github.com/wraps-team/wraps/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "pnpm build:console && pnpm build:lambda && tsup",
    "build:lambda": "tsx scripts/build-lambda.ts",
    "build:console": "pnpm --filter @wraps/console build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "aws",
    "ses",
    "aws-ses",
    "email",
    "sms",
    "cdn",
    "infrastructure",
    "cli",
    "deploy",
    "dkim",
    "spf",
    "dmarc",
    "cloudfront",
    "iac",
    "devops",
    "email-setup",
    "wraps"
  ],
  "author": "Wraps",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@aws-sdk/client-acm": "3.933.0",
    "@aws-sdk/client-cloudformation": "^3.1027.0",
    "@aws-sdk/client-cloudfront": "3.933.0",
    "@aws-sdk/client-cloudwatch": "^3.490.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-iam": "3.932.0",
    "@aws-sdk/client-lambda": "3.925.0",
    "@aws-sdk/client-mailmanager": "3.925.0",
    "@aws-sdk/client-pinpoint-sms-voice-v2": "3.955.0",
    "@aws-sdk/client-route-53": "3.925.0",
    "@aws-sdk/client-s3": "3.981.0",
    "@aws-sdk/client-ses": "^3.490.0",
    "@aws-sdk/client-sesv2": "3.925.0",
    "@aws-sdk/client-sns": "^3.490.0",
    "@aws-sdk/client-sqs": "3.933.0",
    "@aws-sdk/client-sts": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "3.981.0",
    "@aws-sdk/util-dynamodb": "3.927.0",
    "@clack/prompts": "^0.11.0",
    "@pulumi/aws": "^7.15.0",
    "@pulumi/pulumi": "^3.216.0",
    "@react-email/render": "2.0.4",
    "better-auth": "catalog:",
    "conf": "^15.1.0",
    "cosmiconfig": "^9.0.0",
    "esbuild": "^0.25.12",
    "express": "^4.22.1",
    "get-port": "^7.1.0",
    "http-terminator": "^3.2.0",
    "isomorphic-dompurify": "2.32.0",
    "mailparser": "3.9.3",
    "mri": "^1.2.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "react": "19.2.4",
    "tabtab": "^3.0.2",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mailparser": "3.4.6",
    "@types/node": "^20.11.0",
    "@types/react": "19.2.4",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "4.0.7",
    "@wraps/core": "workspace:*",
    "@wraps/email-check": "workspace:*",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-vitest": "7.0.1",
    "tsup": "^8.0.1",
    "tsx": "4.20.6",
    "typescript": "catalog:",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
