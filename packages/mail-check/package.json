  "dependencies": {},
  "devDependencies": {
    "@wraps.dev/email-check": "workspace:*",
    "@types/node": "catalog:",
    "picocolors": "^1.1.1",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
