{
  "name": "@wraps.dev/cdk",
  "version": "0.2.2",
  "description": "AWS CDK L3 construct for email infrastructure. Deploys SES, event processing, email history, and OIDC auth as a single construct with grant methods.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && pnpm build:lambda",
    "build:lambda": "tsx scripts/build-lambda.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "wraps",
    "email",
    "aws",
    "aws-ses",
    "ses",
    "cdk",
    "aws-cdk",
    "construct",
    "infrastructure",
    "iac",
    "cloudformation",
    "l3-construct"
  ],
  "author": "Wraps <hello@wraps.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wraps-team/wraps.git",
    "directory": "packages/cdk"
  },
  "homepage": "https://wraps.dev",
  "bugs": {
    "url": "https://github.com/wraps-team/wraps/issues"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@wraps/core": "workspace:*",
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0",
    "tsup": "catalog:",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
