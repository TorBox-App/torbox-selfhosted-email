{
  "name": "@wraps/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "drizzle-kit studio",
    "build": "tsdown",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:push:test": "dotenv -e ../../apps/web/.env.test -- pnpm --filter=@wraps/db db:push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:activity": "tsx scripts/seed-activity.ts",
    "seed:contacts": "tsx scripts/seed-contacts.ts",
    "seed:demo": "tsx scripts/seed-demo-batches.ts",
    "seed:events": "tsx scripts/seed-events.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/util-dynamodb": "catalog:",
    "@neondatabase/serverless": "^1.1.0",
    "@types/pg": "catalog:",
    "drizzle-kit": "^0.31.10",
    "tsdown": "catalog:",
    "tsx": "^4.22.4",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  }
}
