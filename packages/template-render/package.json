{
  "name": "@wraps/template-render",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical template rendering for Wraps. One place for Handlebars substitution so the dashboard, API, workers, and CLI all render the same way.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./mustache-case": {
      "types": "./dist/mustache-case.d.ts",
      "default": "./src/mustache-case.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gate:ses": "tsx scripts/test-render-all.mjs",
    "repair:ses-text": "tsx scripts/repair-ses-text-parts.mjs"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "handlebars": "catalog:"
  }
}
